# PeriDigital — sitio estático (Next.js export) sobre LiteSpeed/Apache
DirectoryIndex index.html index.php
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Forzar non-www (canonical)
  RewriteCond %{HTTP_HOST} ^www\.peridigital\.es [NC]
  RewriteRule ^(.*)$ https://peridigital.es/$1 [R=301,L]

  # 301: /proyectos-web/ -> /proyectos/ (slug renombrado, preserva SEO).
  # Va antes de la regla que sirve directorios reales, porque el dir viejo
  # /proyectos-web/ sigue en el servidor (deploy FTP aditivo).
  RewriteRule ^proyectos-web/?$ /proyectos/ [R=301,L]
  RewriteRule ^proyectos-web/(.+)$ /proyectos/$1 [R=301,L]

  # Servir ficheros y carpetas reales (assets, artículos, y subsitios: crm, informes, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
</IfModule>

# Imagen Open Graph (fichero sin extensión) servida como PNG
<Files "opengraph-image">
  ForceType image/png
</Files>

# Cache de assets estáticos de Next
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|css|woff2|webp|png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Cache HTML: revalida siempre (contenido editable) pero permite 304 rapido
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>
