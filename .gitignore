# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# proyecto
/backups/
!.env.example

.deploytest/

# Referencia de export en vivo (descargado, no es fuente)
/_ref-live/

# Admin PHP secret (created by setup.php on the server)
server/admin/config.local.php

# Datos propiedad del admin / artefactos de build (no versionar)
server/data/article-images.json
server/data/articles-index.json
